{
	"appId": "com.caisterplayz.social",
	"appName": "CaisterPlayz",
	"webDir": "dist",
	"server": {
		"androidScheme": "https",
		"iosScheme": "https"
	},
	"plugins": {
		"SplashScreen": {
			"launchAutoHide": true,
			"launchShowDuration": 2000,
			"backgroundColor": "#000000",
			"showSpinner": false
		},
		"StatusBar": {
			"style": "DARK",
			"backgroundColor": "#000000"
		}
	},
	"ios": {
		"contentInset": "automatic",
		"preferredContentMode": "mobile",
		"scheme": "CaisterPlayz"
	},
	"packageClassList": [
		"HapticsPlugin",
		"SplashScreenPlugin",
		"StatusBarPlugin"
	]
}
